<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Акции – биржа</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        * { box-sizing: border-box; }
        body { font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif; margin: 0; padding: 12px; background: #f0f2f5; }
        .card { background: white; border-radius: 20px; padding: 16px; margin-bottom: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
        h2, h3 { margin-top: 0; margin-bottom: 12px; }
        p { margin: 8px 0; }
        button { background: #0088cc; color: white; border: none; padding: 12px 16px; border-radius: 40px; font-size: 16px; font-weight: 600; width: 100%; margin-top: 8px; cursor: pointer; transition: 0.2s; }
        button:active { transform: scale(0.97); }
        input { width: 100%; padding: 12px; margin: 8px 0; border: 1px solid #ddd; border-radius: 40px; font-size: 16px; background: #fafafa; }
        .order { border-bottom: 1px solid #eee; padding: 12px 0; display: flex; justify-content: space-between; align-items: center; }
        .order-price { font-weight: bold; color: #2c3e50; }
        .buy-btn { background: #2ecc71; width: auto; padding: 6px 16px; margin: 0; font-size: 14px; }
        .sell-btn { background: #e67e22; width: auto; padding: 6px 16px; margin: 0; font-size: 14px; }
        .inline-buttons { display: flex; gap: 8px; align-items: center; }
    </style>
</head>
<body>
    <div id="app">Загрузка...</div>
    <script>
        // Инициализация Telegram
        const tg = window.Telegram.WebApp;
        tg.ready();
        tg.expand();

        const userId = tg.initDataUnsafe?.user?.id;
        const username = tg.initDataUnsafe?.user?.username || "user_" + userId;

        // --- НАСТРОЙКИ SUPABASE (ЗАМЕНИТЕ НА СВОИ) ---
        const SUPABASE_URL = "https://gsutnhhklidxmewdkcvk.supabase.co";
        const SUPABASE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImdzdXRuaGhrbGlkeG1ld2RrY3ZrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODA1NzA2MTEsImV4cCI6MjA5NjE0NjYxMX0.XEtyJVT0BfmEgAAsGagPHRdHhmCgrtWEbtzov0c3EXc";
        // -------------------------------------------

        const supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

        let currentUser = null;

        async function initUser() {
            if (!userId) {
                document.getElementById('app').innerHTML = '<div class="card">Ошибка: не удалось определить пользователя. Запустите через Telegram.</div>';
                return;
            }
            // Проверяем есть ли пользователь
            let { data, error } = await supabase
                .from('users')
                .select('*')
                .eq('id', userId)
                .single();

            if (error && error.code === 'PGRST116') {
                // Создаём нового
                const { data: newUser, error: insertError } = await supabase
                    .from('users')
                    .insert([{ id: userId, username: username, shares: 100, stars_balance: 50 }])
                    .select()
                    .single();
                if (newUser) currentUser = newUser;
                else currentUser = { id: userId, shares: 100, stars_balance: 50 };
            } else if (data) {
                currentUser = data;
            }
            renderUI();
        }

        async function renderUI() {
            if (!currentUser) return;

            // Получаем активные ордера на продажу
            const { data: orders } = await supabase
                .from('orders')
                .select('*')
                .eq('status', 'active')
                .order('price_per_share', { ascending: true });

            const html = `
                <div class="card">
                    <h2>💰 Мой баланс</h2>
                    <p>📊 Акций: <strong>${currentUser.shares}</strong></p>
                    <p>⭐ Stars: <strong>${currentUser.stars_balance}</strong></p>
                </div>
                <div class="card">
                    <h3>📈 Продать акции</h3>
                    <input type="number" id="sellAmount" placeholder="Количество" min="1">
                    <input type="number" id="sellPrice" placeholder="Цена за 1 акцию (Stars)" min="1">
                    <button id="createSellBtn">➕ Выставить на продажу</button>
                </div>
                <div class="card">
                    <h3>📋 Книга ордеров (продажа)</h3>
                    <div id="ordersList">Загрузка...</div>
                </div>
            `;
            document.getElementById('app').innerHTML = html;

            // Обработчик создания ордера
            document.getElementById('createSellBtn').addEventListener('click', async () => {
                const amount = parseInt(document.getElementById('sellAmount').value);
                const price = parseInt(document.getElementById('sellPrice').value);
                if (isNaN(amount) || isNaN(price) || amount <= 0 || price <= 0) {
                    alert('Введите корректные количество и цену');
                    return;
                }
                if (currentUser.shares < amount) {
                    alert(`Недостаточно акций. У вас только ${currentUser.shares}`);
                    return;
                }
                // Создаём ордер в БД
                const { error } = await supabase
                    .from('orders')
                    .insert([{
                        seller_id: userId,
                        amount: amount,
                        price_per_share: price,
                        status: 'active'
                    }]);
                if (error) {
                    alert('Ошибка создания ордера');
                    console.error(error);
                } else {
                    // Списать акции у продавца локально и в БД
                    const newShares = currentUser.shares - amount;
                    await supabase.from('users').update({ shares: newShares }).eq('id', userId);
                    currentUser.shares = newShares;
                    renderUI(); // обновляем интерфейс
                }
            });

            // Отображаем ордера
            const ordersDiv = document.getElementById('ordersList');
            if (orders && orders.length > 0) {
                ordersDiv.innerHTML = orders.map(order => `
                    <div class="order">
                        <div>
                            <span class="order-price">${order.price_per_share} ⭐</span> за шт.<br>
                            📦 ${order.amount} шт. (всего ${order.amount * order.price_per_share} ⭐)
                        </div>
                        <div class="inline-buttons">
                            <button class="buy-btn" data-order-id="${order.id}" data-price="${order.price_per_share}" data-amount="${order.amount}" data-seller="${order.seller_id}">Купить</button>
                        </div>
                    </div>
                `).join('');
                // Добавляем обработчики на кнопки "Купить"
                document.querySelectorAll('.buy-btn').forEach(btn => {
                    btn.addEventListener('click', async (e) => {
                        const orderId = parseInt(btn.dataset.orderId);
                        const price = parseInt(btn.dataset.price);
                        const amount = parseInt(btn.dataset.amount);
                        const sellerId = parseInt(btn.dataset.seller);
                        const totalStars = price * amount;
                        if (currentUser.stars_balance < totalStars) {
                            alert(`Недостаточно Stars. Нужно ${totalStars}, у вас ${currentUser.stars_balance}`);
                            return;
                        }
                        // Выполняем сделку: списываем Stars у покупателя, начисляем акции, переводим Stars продавцу, закрываем ордер
                        const { error: buyerUpdate } = await supabase
                            .from('users')
                            .update({ stars_balance: currentUser.stars_balance - totalStars })
                            .eq('id', userId);
                        if (buyerUpdate) return alert('Ошибка списания Stars');

                        const { error: buyerShares } = await supabase
                            .from('users')
                            .update({ shares: currentUser.shares + amount })
                            .eq('id', userId);
                        if (buyerShares) return alert('Ошибка начисления акций');

                        // Получаем текущий баланс продавца
                        const { data: sellerData } = await supabase
                            .from('users')
                            .select('stars_balance')
                            .eq('id', sellerId)
                            .single();
                        await supabase
                            .from('users')
                            .update({ stars_balance: sellerData.stars_balance + totalStars })
                            .eq('id', sellerId);

                        // Закрываем ордер
                        await supabase.from('orders').update({ status: 'completed' }).eq('id', orderId);

                        // Обновляем локального пользователя
                        currentUser.stars_balance -= totalStars;
                        currentUser.shares += amount;
                        renderUI();
                        alert('Сделка успешно завершена!');
                    });
                });
            } else {
                ordersDiv.innerHTML = '<p>Нет активных ордеров на продажу. Будьте первым!</p>';
            }
        }

        initUser();
    </script>
</body>
</html>
